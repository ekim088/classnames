{
	"compilerOptions": {
		"rootDir": "./src",
		"lib": ["es2015", "dom"],
		"moduleResolution": "node",
		"removeComments": true,
		"sourceMap": true,
		"strict": true,
		"target": "es5",
		"downlevelIteration": true,
		"ignoreDeprecations": "6.0"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "**/__tests__", "**/*.test.ts"]
}
