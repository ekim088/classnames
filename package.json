{
	"name": "@ekim088/classnames",
	"description": "Reduces mixed-type arguments into a single HTML class attribute.",
	"version": "2.0.0",
	"author": "ekim088 <edward@cyberbird.co>",
	"bugs": {
		"url": "https://github.com/ekim088/classnames/issues"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@types/classnames": "^2.3.4",
		"@types/jest": "^29.5.14",
		"@typescript-eslint/eslint-plugin": "^8.32.1",
		"@typescript-eslint/parser": "^8.32.1",
		"benchmark": "^2.1.4",
		"classnames": "^2.5.1",
		"eslint": "^8.2.0",
		"eslint-config-airbnb-base": "^15.0.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-import-resolver-typescript": "^4.3.5",
		"eslint-plugin-import": "^2.25.2",
		"eslint-plugin-jest": "^28.11.0",
		"eslint-plugin-jsdoc": "^50.6.17",
		"husky": "^9.1.7",
		"jest": "^29.7.0",
		"lint-staged": "^16.0.0",
		"pinst": "^3.0.0",
		"prettier": "^3.5.3",
		"ts-jest": "^29.3.4",
		"typescript": "^5.8.3"
	},
	"exports": {
		".": {
			"types": "./lib/cjs/index.d.ts",
			"import": "./lib/esm/index.js",
			"require": "./lib/cjs/index.js"
		},
		"./cached": {
			"types": "./lib/cjs/cached.d.ts",
			"import": "./lib/esm/cached.js",
			"require": "./lib/cjs/cached.js"
		},
		"./dedupe": {
			"types": "./lib/cjs/dedupe.d.ts",
			"import": "./lib/esm/dedupe.js",
			"require": "./lib/cjs/dedupe.js"
		},
		"./package.json": "./package.json"
	},
	"homepage": "https://github.com/ekim088/classnames#readme",
	"keywords": [
		"classnames"
	],
	"license": "MIT",
	"lint-staged": {
		"*.(j|t)s": [
			"yarn eslint --fix",
			"yarn test:pre-commit",
			"yarn prettier --write"
		],
		"*.(json|md|*rc)": [
			"yarn prettier --write"
		]
	},
	"main": "./lib/cjs/index.js",
	"module": "./lib/esm/index.js",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ekim088/classnames.git"
	},
	"scripts": {
		"benchmark": "npm run build && node ./benchmark",
		"build": "node -e \"require('node:fs').rmSync('./lib', { recursive: true, force: true })\" && yarn build:cjs && yarn build:esm",
		"build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('node:fs').writeFileSync('./lib/cjs/package.json', '{\\\"type\\\":\\\"commonjs\\\"}')\"",
		"build:esm": "tsc -p tsconfig.esm.json && node -e \"require('node:fs').writeFileSync('./lib/esm/package.json', '{\\\"type\\\":\\\"module\\\"}')\"",
		"lint": "eslint . --ext .js,.ts --fix",
		"postinstall": "husky",
		"prepack": "pinst --disable",
		"postpack": "pinst --enable",
		"test": "jest --watchAll",
		"test:ci": "jest",
		"test:coverage": "jest --collectCoverage",
		"test:pre-commit": "jest --findRelatedTests --passWithNoTests"
	},
	"types": "./lib/cjs/index.d.ts",
	"volta": {
		"node": "22.16.0",
		"yarn": "4.9.1"
	}
}
